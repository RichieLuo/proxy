{
  "manifest_version": 3,
  "name": "域名定向代理",
  "version": "1.0.0",
  "description": "只对匹配域名走代理的 Chrome 扩展",
  "permissions": ["proxy", "storage", "tabs"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "域名定向代理"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
