{
  "manifest_version": 3,
  "name": "Selective Domain Proxy",
  "version": "1.0.0",
  "description": "只对匹配白名单域名的标签页走代理 - Proxy only tabs whose URL domain matches the whitelist",
  "permissions": ["proxy", "storage", "tabs"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Selective Domain Proxy"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
